# ─── Notion Internal Integration Token ─────────────────────────────────
# 1. Go to notion.so/profile/integrations
# 2. Click "New integration" → type: Internal
# 3. Copy the "Internal Integration Secret" (starts with secret_...)
# 4. Share your Transactions, Categories, and Accounts databases with this integration
NOTION_TOKEN=

# ─── Notion Databases (already configured) ────────────────────────────────────
NOTION_TRANSACTIONS_DB=
NOTION_CATEGORIES_DB=
NOTION_ACCOUNTS_DB=
